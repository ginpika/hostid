# ===========================================
# Frontend Environment Variables
# Copy this file to .env in the frontend directory
# ===========================================

# ----- Cloudflare Turnstile (Optional) -----
# Bot protection for registration page
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile

# Cloudflare Turnstile Site Key (client-side widget)
# Must start with VITE_ to be exposed to the browser
CF_TURNSTILE_SITE_KEY=
