# ===========================================
# Docker Deployment Environment Variables
# Copy this file to .env in the project root for Docker deployment
# ===========================================

# ----- Database -----
# SQLite database path (Docker volume)
DATABASE_URL="file:/app/data/prod.db"

# ----- Security -----
# JWT secret key for authentication tokens
# IMPORTANT: Generate a secure random string for production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ----- Domain -----
# Your mail domain (e.g., mail.example.com)
MAIL_DOMAIN=yourdomain.com

# SSO login page URL for redirects (e.g., https://mail.a.com/login)
SSO_LOGIN_PAGE_URL=

# ----- Ports -----
# Web interface port (default: 80)
PORT=80

# SMTP server port for receiving emails (default: 25)
# Note: Port 25 requires root privileges
SMTP_PORT=25

# ----- SMTP Relay (Optional) -----
# Configure if you want to relay emails through an external SMTP server
# If not configured, the system will attempt direct delivery via MX records

# SMTP relay server hostname
SMTP_HOST=

# SMTP relay server port
SMTP_OUT_PORT=25

# SMTP authentication username
SMTP_USER=

# SMTP authentication password
SMTP_PASS=

# ----- Cloudflare Turnstile (Optional) -----
# Bot protection for registration page
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile

# Cloudflare Turnstile Secret Key (server-side verification)
CF_TURNSTILE_SECRET_KEY=

# Cloudflare Turnstile Site Key (client-side widget, for frontend build)
CF_TURNSTILE_SITE_KEY=

# ----- SSO Configuration -----
# Cookie domain for SSO (e.g., .example.com for all subdomains)
# Leave empty for single domain deployment
SSO_COOKIE_DOMAIN=

# Cookie name for SSO token
SSO_COOKIE_NAME=sso_token

# Cookie path (default: /)
SSO_COOKIE_PATH=/

# Cookie secure flag (true for HTTPS, false for HTTP)
SSO_COOKIE_SECURE=false

# Cookie SameSite attribute (strict, lax, or none)
SSO_COOKIE_SAMESITE=lax

# Session TTL in seconds (default: 7 days)
SESSION_TTL=604800

# SSO login page URL for redirects (e.g., https://mail.a.com/login)
# Used when SSO clients redirect to /sso/login
SSO_LOGIN_PAGE_URL=
