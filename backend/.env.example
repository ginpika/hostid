# ===========================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ===========================================

# ----- Database -----
# SQLite database URL (for development)
DATABASE_URL="file:./db.db"

# ----- Security -----
# JWT secret key for authentication tokens
# Generate a secure random string for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# ----- Server -----
# API server port (default: 3001)
# When you change here, you need to update ./frontend/nginx.conf proxy port as well
PORT=3001

# SSO login page URL for redirects (e.g., https://mail.a.com/login)
SSO_LOGIN_PAGE_URL=

# Your mail domain (e.g., example.com)
MAIL_DOMAIN="yourdomain.com"

# ----- SMTP Server (Receiving Emails) -----
# Port for incoming SMTP connections (default: 25)
# Note: Port 25 requires root privileges, use 2525 for development
SMTP_PORT=2525

# ----- SMTP Relay (Sending External Emails) -----
# Optional: Configure if you want to relay emails through an external SMTP server
# If not configured, the system will attempt direct delivery via MX records

# SMTP relay server hostname
SMTP_HOST=

# SMTP relay server port (default: 25)
SMTP_OUT_PORT=25

# SMTP authentication username
SMTP_USER=

# SMTP authentication password
SMTP_PASS=

# ----- Cloudflare Turnstile (Optional) -----
# Bot protection for registration page
# Get your keys at: https://dash.cloudflare.com/?to=/:account/turnstile

# Cloudflare Turnstile Secret Key (server-side verification), if not set, turnstile will be disabled
# CF_TURNSTILE_SECRET_KEY=

# ----- SSO Configuration -----
# Cookie domain for SSO (e.g., .example.com for all subdomains)
# Leave empty for single domain deployment
SSO_COOKIE_DOMAIN=

# Cookie name for SSO token
SSO_COOKIE_NAME=sso_token

# Cookie path (default: /)
SSO_COOKIE_PATH=/

# Cookie secure flag (true for HTTPS, false for HTTP)
SSO_COOKIE_SECURE=false

# Cookie sameSite attribute (strict, lax, none)
SSO_COOKIE_SAMESITE=lax

# Session TTL in seconds (default: 7 days)
SESSION_TTL=604800

# ----- GitHub OAuth Configuration -----
# GitHub OAuth App Client ID
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=

# GitHub OAuth App Client Secret
GITHUB_CLIENT_SECRET=

# GitHub OAuth Callback URL (e.g., http://localhost:3001/api/oauth/github/callback)
GITHUB_CALLBACK_URL=

# Frontend URL for OAuth redirects (e.g., http://localhost:5173)
FRONTEND_URL=
